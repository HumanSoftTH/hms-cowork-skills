{
  "acp-analytics": {
    "command": "node",
    "args": ["${CLAUDE_PLUGIN_ROOT}/mcp-servers/analytics/server.cjs"],
    "env": {
      "ACP_USERNAME": "${ACP_USERNAME}",
      "ACP_PASSWORD": "${ACP_PASSWORD}"
    }
  },
  "acp-crm": {
    "command": "node",
    "args": ["${CLAUDE_PLUGIN_ROOT}/mcp-servers/crm/server.cjs"],
    "env": {
      "ACP_USERNAME": "${ACP_USERNAME}",
      "ACP_PASSWORD": "${ACP_PASSWORD}"
    }
  }
}
